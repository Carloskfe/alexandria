{
  "expo": {
    "name": "Noetia",
    "slug": "noetia",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noetia.app",
      "usesAppleSignIn": true,
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.noetia.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1
    },
    "scheme": "noetia",
    "plugins": [
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "99e71dcb-bfa3-4c8d-bb74-2d20edbb1826"
      }
    },
    "owner": "carloskfe"
  }
}
