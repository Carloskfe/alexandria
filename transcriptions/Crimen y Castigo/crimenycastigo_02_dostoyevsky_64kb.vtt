465
00:18:58.169 --> 00:18:58.969
Entonces,

466
00:18:58.970 --> 00:18:59.690
señor,

467
00:18:59.850 --> 00:19:00.889
entonces,

468
00:19:01.129 --> 00:19:01.849
yo,

469
00:19:02.009 --> 00:19:03.529
