5884
03:53:49.047 --> 03:53:50.247
miocenos,

5885
03:53:50.327 --> 03:53:51.367
eosenos,

5886
03:53:51.367 --> 03:53:52.327
cretáceos,

5887
03:53:52.327 --> 03:53:53.367
jurásicos,

5888
03:53:53.527 --> 03:53:54.647
triásicos,

5889
03:53:54.727 --> 03:53:55.847
pernianos,

5890
03:53:55.927 --> 03:53:57.047
carboníferos,

5891
03:53:57.286 --> 03:53:58.087
degonianos,

5892
